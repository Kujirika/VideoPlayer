<Window x:Class="MinimalPlayback.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        Title="Minimal VLC Player" Height="800" Width="1500">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- Левая часть -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Видео -->
            <vlc:VideoView x:Name="videoView" Grid.Row="0"/>

            <!-- Панель управления -->
            <StackPanel Orientation="Horizontal"
                        Grid.Row="1"
                        Margin="10"
                        VerticalAlignment="Center">

                <Button x:Name="PlayPauseBtn"
                        Content="Pause"
                        Click="PlayPauseBtn_Click"
                        Margin="5"/>

                <Button x:Name="Browse"
                        Content="Browse"
                        Click="Browse_Click"
                        Margin="5"/>

                <Button x:Name="PlaylistBtn"
                        Content="Playlist"
                        Click="PlaylistBtn_Click"
                        Margin="5"/>

                <!-- Конвертация -->
                <Button Content="Convert"
                        Click="OpenConvertWindow_Click"
                        Margin="5"/>

                <TextBlock x:Name="CurrentTimeText"
                           Text="00:00"
                           VerticalAlignment="Center"
                           Margin="10,0"/>

                <Slider x:Name="Slider"
                        Minimum="0"
                        ValueChanged="Slider_ValueChanged"
                        PreviewMouseDown="Slider_PreviewMouseDown"
                        PreviewMouseUp="Slider_PreviewMouseUp"
                        MouseMove="Slider_MouseMove"
                        MouseLeave="Slider_MouseLeave"
                        ToolTipService.InitialShowDelay="0"
                        VerticalAlignment="Center"
                        Margin="10,0"
                        Width="500"/>

                <TextBlock x:Name="TotalTimeText"
                           Text="00:00"
                           VerticalAlignment="Center"
                           Margin="10,0"/>
            </StackPanel>
        </Grid>

        <!-- Правая часть -->
        <ListBox x:Name="PlaylistListBox"
                 Grid.Column="1"
                 Margin="5"
                 Visibility="Collapsed"
                 SelectionChanged="PlaylistListBox_SelectionChanged"/>
    </Grid>
</Window>